<IfModule mod_rewrite.c>
DirectoryIndex index.php
RewriteEngine On

# Redirect index.php ke folder (GET/HEAD saja)
RewriteCond %{REQUEST_METHOD} =GET [OR]
RewriteCond %{REQUEST_METHOD} =HEAD
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.php[\s?] [NC]
RewriteRule ^(.*/)?index\.php$ $1 [R=302,L]

# Hilangkan ekstensi .php (GET/HEAD saja)
RewriteCond %{REQUEST_METHOD} =GET [OR]
RewriteCond %{REQUEST_METHOD} =HEAD
RewriteCond %{THE_REQUEST} \s/+([^\s?]+?)\.php[\s?] [NC]
RewriteRule ^(.+)\.php$ $1 [R=302,L]

# Lewati jika file/folder fisik ada (agar DirectoryIndex memuat index.php)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Rewrite internal: URL tanpa ekstensi → file .php
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]
</IfModule>

# Prevent directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "\.(sql|log|ini)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Error pages
ErrorDocument 404 404.php
ErrorDocument 403 403.php




