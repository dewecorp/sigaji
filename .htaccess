Options -Indexes -MultiViews
DirectoryIndex index.php

RedirectMatch 302 ^/[A-Za-z]:/.*/sistem_gaji/(.*)$ /$1

<IfModule mod_headers.c>
Header always set X-Content-Type-Options "nosniff"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

<IfModule mod_rewrite.c>
RewriteEngine On

RewriteCond %{REQUEST_URI} ^/[A-Za-z]:/.*/sistem_gaji/(.*)$ [NC]
RewriteRule ^ %1 [R=302,L]

RewriteRule ^(?:config|database|vendor|backup)/ - [F,L,NC]
RewriteRule ^(?:\.git|\.svn|\.hg)/ - [F,L,NC]
RewriteRule ^(?:composer\.(?:json|lock)|\.env|\.gitignore|_cookies\.txt|.*\.(?:bat|sh|ps1))$ - [F,L,NC]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]
</IfModule>

# Protect sensitive files
<FilesMatch "\.(sql|log|ini|bak|dist|old|env|phar|phtml)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

<FilesMatch "^(composer\.(json|lock)|\.env|\.gitignore|_cookies\.txt|.*\.(bat|sh|ps1))$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
