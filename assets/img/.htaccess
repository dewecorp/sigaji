# Prevent PHP execution in upload directory
<FilesMatch "\.(php|phtml|php3|php4|php5|phar|pl|cgi|py|rb|asp|aspx|jsp)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
